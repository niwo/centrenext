{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["navigation", "hero", "about", "team", "services", "news", "location", "footer"],
  "additionalProperties": false,
  "properties": {
    "navigation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "href"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "href": { "type": "string", "minLength": 1 }
        }
      }
    },
    "hero": {
      "type": "object",
      "required": ["eyebrow", "title", "description", "primaryCta", "secondaryCta"],
      "additionalProperties": false,
      "properties": {
        "eyebrow": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "primaryCta": { "$ref": "#/$defs/cta" },
        "secondaryCta": { "$ref": "#/$defs/cta" }
      }
    },
    "about": {
      "type": "object",
      "required": ["title"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" }
      }
    },
    "team": {
      "type": "object",
      "required": ["title", "intro", "people"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "intro": { "type": "string" },
        "people": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "role", "specialties"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "email": { "type": "string" },
              "phone": { "type": "string" },
              "image": { "type": "string" },
              "specialties": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "services": {
      "type": "object",
      "required": ["title", "intro", "items"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "intro": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description", "price"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "price": { "type": "string" }
            }
          }
        }
      }
    },
    "news": {
      "type": "object",
      "required": ["title", "intro", "items"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "intro": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "date", "excerpt"],
            "additionalProperties": false,
            "properties": {
              "title": { "type": "string" },
              "date": { "type": "string" },
              "excerpt": { "type": "string" }
            }
          }
        }
      }
    },
    "location": {
      "type": "object",
      "required": ["title", "intro", "addressLabel", "openingHoursLabel", "mapLabel"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "intro": { "type": "string" },
        "addressLabel": { "type": "string" },
        "openingHoursLabel": { "type": "string" },
        "mapLabel": { "type": "string" }
      }
    },
    "footer": {
      "type": "object",
      "required": ["tagline", "copyright"],
      "additionalProperties": false,
      "properties": {
        "tagline": { "type": "string" },
        "copyright": { "type": "string" }
      }
    }
  },
  "$defs": {
    "cta": {
      "type": "object",
      "required": ["label", "href"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" },
        "href": { "type": "string" }
      }
    }
  }
}