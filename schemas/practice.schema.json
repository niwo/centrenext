{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["name", "addressLines", "mapEmbedUrl", "contact", "openingHours"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "addressLines": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string" }
    },
    "mapEmbedUrl": { "type": "string", "minLength": 1 },
    "contact": {
      "type": "object",
      "required": ["phone", "email"],
      "additionalProperties": false,
      "properties": {
        "phone": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "openingHours": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["day", "hours"],
        "additionalProperties": false,
        "properties": {
          "day": { "type": "string" },
          "hours": { "type": "string" }
        }
      }
    }
  }
}