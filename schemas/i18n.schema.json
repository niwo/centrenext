{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["landing", "days", "nav", "hero", "about", "team", "services", "posts", "location", "footer", "testimonials"],
  "properties": {
    "landing": {
      "type": "object",
      "required": ["localeLinkLabel"]
    },
    "days": { "type": "object" },
    "nav": {
      "type": "object",
      "required": ["about", "team", "services", "posts", "search", "location"]
    },
    "hero": {
      "type": "object",
      "required": ["eyebrow", "title", "primaryCta", "secondaryCta"]
    },
    "about": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "team": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "specialties": { "type": "object" },
    "services": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "posts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "footer": {
      "type": "object",
      "required": ["contactKicker", "backLink", "detailKicker", "emailLabel", "phoneLabel", "adminLabel"]
    },
    "testimonials": {
      "type": "object",
      "required": ["kicker", "title"]
    }
  },
  "additionalProperties": false
}
