{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["landing", "days", "nav", "hero", "about", "team", "services", "posts", "location", "footer", "testimonials"],
  "properties": {
    "landing": {
      "type": "object",
      "required": ["localeLinkLabel"]
    },
    "days": { "type": "object" },
    "nav": {
      "type": "object",
      "required": ["about", "team", "services", "posts", "search", "location"]
    },
    "hero": {
      "type": "object",
      "required": ["eyebrow", "title", "primaryCta", "secondaryCta"]
    },
    "about": {
      "type": "object",
      "required": ["title", "detailLink"]
    },
    "team": {
      "type": "object",
      "required": ["title", "intro", "detailLink"]
    },
    "specialties": { "type": "object" },
    "services": {
      "type": "object",
      "required": [
        "title",
        "pricePrefix",
        "detailLink",
        "priceLabel",
        "unitLabel",
        "unitSessionLabel",
        "insuranceLabel",
        "insuranceObligatoryLabel",
        "insuranceSupplementaryLabel",
        "insuranceNoCoverageLabel",
        "insuranceSupplementaryInsurersLabel",
        "insuranceCoveredLabel",
        "insuranceNotCoveredLabel"
      ]
    },
    "posts": {
      "type": "object",
      "required": ["title", "sectionTitle", "detailLink"]
    },
    "location": {
      "type": "object",
      "required": ["title", "detailLink", "addressLabel", "openingHoursLabel", "mapLabel"]
    },
    "footer": {
      "type": "object",
      "required": ["contactKicker", "backLink", "detailKicker"]
    },
    "testimonials": {
      "type": "object",
      "required": ["kicker", "title"]
    }
  },
  "additionalProperties": false
}
