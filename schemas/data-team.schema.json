          "id",
          "name",
          "email",
          "phone",
          "image",
          "specialtyKeys"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "titles": {
            "type": "object",
            "properties": {
              "de": { "type": "string" },
              "fr": { "type": "string" }
            },
            "additionalProperties": false
          },
          "slogans": {
            "type": "object",
            "properties": {
              "de": { "type": "string" },
              "fr": { "type": "string" }
            },
            "additionalProperties": false
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "image": {
            "type": "string"
          },
          "headerImage": {
            "type": "string"
          },
          "specialtyKeys": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
