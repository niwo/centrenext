{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "name", "email", "phone", "image", "tags", "profile"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "email": { "type": "string" },
    "profile": {
      "type": "object",
      "required": ["de", "fr"],
      "properties": {
        "de": {
          "type": "object",
          "required": ["role", "content"],
          "properties": {
            "role": { "type": "string" },
            "slogan": { "type": "string" },
            "content": { "type": "string" }
          },
          "additionalProperties": false
        },
        "fr": {
          "type": "object",
          "required": ["role", "content"],
          "properties": {
            "role": { "type": "string" },
            "slogan": { "type": "string" },
            "content": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "phone": { "type": "string" },
    "socialLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["platform", "href"],
        "properties": {
          "platform": {
            "type": "string",
            "enum": ["website", "instagram", "linkedin"]
          },
          "href": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "image": { "type": "string" },
    "headerImage": { "type": "string" },
    "schedule": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["day", "periods"],
        "properties": {
          "day": {
            "type": "string",
            "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"]
          },
          "periods": {
            "type": "array",
            "items": { "type": "string", "enum": ["morning", "afternoon"] },
            "minItems": 1
          }
        },
        "additionalProperties": false
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
